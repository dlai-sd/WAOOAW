{
  "name": "WAOOAW Development",
  "image": "python:3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/google-cloud-cli:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "python.terminal.activateEnvironment": false,
        "python.testing.pytestEnabled": false,
        "chat.promptFiles": true
      }
    }
  },
  "postCreateCommand": "install -m 0755 .devcontainer/00-token-alias.sh /etc/profile.d/00-waooaw-token-alias.sh && bash .devcontainer/gcp-auth.sh",
  "forwardPorts": [3001, 3002, 8000, 8001, 8015, 8020, 8081, 5555, 15432],
  "remoteUser": "root"
}
