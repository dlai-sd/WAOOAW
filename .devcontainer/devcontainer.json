{
  "name": "WAOOAW Development",
  "image": "python:3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/google-cloud-cli:1": {
      "version": "latest",
      "installAdditionalComponents": false
    }
  },
  "postCreateCommand": "bash .devcontainer/gcp-auth.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "python.testing.pytestEnabled": true
      }
    }
  },
  "forwardPorts": [3000, 5432, 8000, 8001, 8080],
  "remoteUser": "root",
  "containerEnv": {
    "CLOUDSDK_CORE_PROJECT": "waooaw-oauth"
  }
}
