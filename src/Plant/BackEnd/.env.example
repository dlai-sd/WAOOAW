# WAOOAW Plant Phase - Environment Configuration Template
# Copy to .env and configure your values

# Application
APP_NAME="WAOOAW Plant Phase API"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
DEBUG=true
LOG_LEVEL="info"

# Database
DATABASE_URL="postgresql://plant_user:plant_password@localhost:5432/plant_db"
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Redis
REDIS_URL="redis://localhost:6379/0"
REDIS_TTL_SECONDS=86400

# ML Service
ML_SERVICE_URL="http://localhost:8005"
ML_SERVICE_TIMEOUT_MS=100
ML_EMBEDDING_DIMENSION=384
ML_MODEL="MiniLM-384"

# Security
SECRET_KEY="your-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Cryptography
RSA_KEY_SIZE=4096
HASH_ALGORITHM="SHA256"

# Performance SLAs
VALIDATE_SELF_SLA_MS=10
EVOLVE_SLA_MS=5
VERIFY_AMENDMENT_SLA_MS=20
PGVECTOR_SEARCH_SLA_MS=500
SCHEMA_MIGRATION_SLA_LATENCY_INCREASE_PERCENT=10

# Cost Governance
EMBEDDING_QUALITY_STABILITY_THRESHOLD=0.85
EMBEDDING_QUALITY_CHECK_SCHEDULE="02:00"

# API
API_V1_PREFIX="/api/v1"
# CORS — explicit origins only, never * in staging/prod (E3-S1 Iteration 3)
# Dev:     http://localhost:3000,http://localhost:8015,http://localhost:5173
# Staging: https://cp.demo.waooaw.com
# Prod:    https://cp.waooaw.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8015,http://localhost:5173,http://localhost:8080

# Google OAuth (mobile token aud verification)
GOOGLE_CLIENT_ID=

# Audit API service key — must match CP backend AUDIT_SERVICE_KEY
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUDIT_SERVICE_KEY=dev-audit-key-change-in-production

# Registration key (issued by Plant Gateway to CP backend)
CP_REGISTRATION_KEY=dev-registration-key-change-in-production

# Celery (Iteration 4 — Async Infrastructure)
# Broker uses Redis DB 4; Result backend uses Redis DB 5 (separate from app cache)
CELERY_BROKER_URL=redis://localhost:6379/4
CELERY_RESULT_BACKEND=redis://localhost:6379/5

# Email provider (Iteration 4 — NOTIF-2)
# EMAIL_PROVIDER=null       → safe default (no emails sent); use in dev/test
# EMAIL_PROVIDER=smtp       → real SMTP delivery
#
# Google Workspace SMTP Relay — uses your existing dlaisd.com Google Workspace subscription
#   Admin Console setup (one-time):
#   1. admin.google.com → Apps → Google Workspace → Gmail → Routing → SMTP relay service
#   2. Enable: Require SMTP Authentication + Require TLS encryption → Save
#   3. For the sending account (customer.care@dlaisd.com):
#      myaccount.google.com → Security → 2-Step Verification → enable
#      then Security → App Passwords → create one named "WAOOAW SMTP" → copy 16-char key
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_USERNAME=customer.care@dlaisd.com
SMTP_PASSWORD=                   # 16-char App Password from Google Account
SMTP_FROM_EMAIL=customer.care@dlaisd.com
SMTP_USE_TLS=true

# ── Observability (Iteration 5) ─────────────────────────────────────────────
# OTEL_EXPORTER: "console" (local dev, default) or "gcp" (staging / prod)
OTEL_EXPORTER=console
# OTEL_SAMPLING_RATE: 0.0–1.0  (1.0 = 100 %, 0.1 = 10 %)
OTEL_SAMPLING_RATE=1.0
# SERVICE_NAME: shown in Cloud Trace / console spans
SERVICE_NAME=plant-backend
# GCP_PROJECT_ID: required when OTEL_EXPORTER=gcp
GCP_PROJECT_ID=waooaw-demo
