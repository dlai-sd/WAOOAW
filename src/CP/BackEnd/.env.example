# WAOOAW Customer Portal — Environment Variables
# Copy this file to .env and fill in the values.
# All variables listed here MUST be set in every environment.
#
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
# For production, use Cloud Run Secret Manager — never commit plain .env files.

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=WAOOAW Customer Portal API
APP_VERSION=0.1.0
ENVIRONMENT=development

# ── JWT ──────────────────────────────────────────────────────────────────────
# Must be a long (>=32 char) random secret. NEVER use the default in prod.
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=

# ── URLs ──────────────────────────────────────────────────────────────────────
# Plant Gateway (public-facing gateway in front of Plant Backend)
PLANT_GATEWAY_URL=http://localhost:8000
# Plant Backend direct URL (server-to-server: audit calls)
PLANT_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. NEVER use * in staging/prod.
# Dev:     http://localhost:3000,http://localhost:8015,http://localhost:5173
# Staging: https://cp.demo.waooaw.com
# Prod:    https://cp.waooaw.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8015,http://localhost:5173,http://localhost:8080

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/waooaw_cp

# ── Audit API ────────────────────────────────────────────────────────────────
# Must match AUDIT_SERVICE_KEY in Plant backend.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUDIT_SERVICE_KEY=dev-audit-key-change-in-production

# ── Registration ──────────────────────────────────────────────────────────────
CP_REGISTRATION_KEY=dev-registration-key-change-in-production

# ── CAPTCHA (Cloudflare Turnstile) ───────────────────────────────────────────
# Leave blank in dev to skip CAPTCHA verification
TURNSTILE_SECRET_KEY=

# ── OTP Email Delivery (login 2FA + registration verification) ───────────────
# Provider: set to "smtp" to enable real email, leave blank in dev/test (raises error if blank in prod)
CP_OTP_DELIVERY_PROVIDER=smtp
#
# Google Workspace SMTP Relay — uses your existing dlaisd.com Google Workspace subscription
#   Admin Console setup (one-time):
#   1. admin.google.com → Apps → Google Workspace → Gmail → Routing → SMTP relay service
#   2. Enable: Require SMTP Authentication + Require TLS encryption → Save
#   3. For the sending account (customer.care@dlaisd.com):
#      myaccount.google.com → Security → 2-Step Verification → enable
#      then Security → App Passwords → create one named "WAOOAW SMTP" → copy 16-char key
CP_OTP_SMTP_HOST=smtp-relay.gmail.com
CP_OTP_SMTP_PORT=587
CP_OTP_SMTP_USERNAME=customer.care@dlaisd.com
CP_OTP_SMTP_PASSWORD=                   # 16-char App Password from Google Account
CP_OTP_SMTP_FROM=customer.care@dlaisd.com
CP_OTP_SMTP_STARTTLS=true
CP_OTP_SMTP_ALLOW_INSECURE=false
