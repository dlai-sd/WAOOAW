# WAOOAW Mobile Local Development Environment Variables
# Copy this file to .env.local and fill in your local values
# .env.local is gitignored — never commit secrets to source code

# Environment identifier (development/demo/uat/prod)
EXPO_PUBLIC_ENVIRONMENT=development

# API Gateway URL
EXPO_PUBLIC_API_URL=http://localhost:8001

# Google OAuth Client IDs (from your local GCP project)
# For local development, you can use the same demo credentials below,
# or create a separate local GCP project and use those credentials

# Option A: Use demo environment credentials (for quick testing)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=270293855600-2shlgotsrqhv8doda15kr8noh74jjpcu.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=270293855600-uoag582a6r5eqq4ho43l3mrvob6gpdmq.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=270293855600-2shlgotsrqhv8doda15kr8noh74jjpcu.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=270293855600-2shlgotsrqhv8doda15kr8noh74jjpcu.apps.googleusercontent.com

# OAuth redirect scheme for local development
EXPO_PUBLIC_OAUTH_REDIRECT_SCHEME=com.waooaw.dev

# Optional: Override environment for testing (if different from EAS profile)
# ENVIRONMENT_OVERRIDE=demo

# Optional: EAS Build Profile override
# EAS_BUILD_PROFILE=development
